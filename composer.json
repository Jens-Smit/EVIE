{
    "name": "jens-smit/evie",
    "type": "project",
    "description": "Selbst-evolvierender AI-Agent basierend auf Symfony AI Bundle",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/symfony": "^7.0",
        "symfony/orm-pack": "^2.0",
        "doctrine/doctrine-bundle": "^2.10",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "symfony/maker-bundle": "^1.50",
        "symfony/ai-bundle": "^0.11.1",
        "symfony/ai-agent": "^0.11",
        "symfony/ai-store": "^0.11"
    },
    "require-dev": {
        "symfony/test-pack": "^1.2",
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.dist', '.env');\""
        ],
        "post-update-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.dist', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}